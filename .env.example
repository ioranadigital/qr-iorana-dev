# ── Node.js ───────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Supabase ──────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── CORS / dominio público ───────────────────────────
ALLOWED_ORIGIN=https://qr.iorana.dev

# ── Sesión (login del panel /api/login) ──────────────
SESSION_SECRET=changeme-set-in-env
ADMIN_USER=admin@example.com
ADMIN_PASS=changeme

# ── HTTP Basic Auth (muro global) ────────────────────
# Si AMBAS variables están definidas, todas las peticiones
# (páginas, API y assets) exigen estas credenciales via
# el popup nativo del navegador. Si falta alguna, el muro
# se desactiva (útil para desarrollo local).
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# ── Slugs amigables ───────────────────────────────────
SLUG_DOMAINS=iorana.digital
SLUG_PREFIX=r
